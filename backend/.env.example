# Retlify environment - copy to .env and fill in.
# Required variables are marked REQUIRED. Everything else is optional.

# Core
NODE_ENV=production
PORT=5000

# Database (REQUIRED)
# MongoDB Atlas connection string - must not contain REPLACE_USER
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/retlify?retryWrites=true&w=majority
MONGO_POOL_SIZE=50

# Redis (optional but REQUIRED for 10k+ users)
# Without this, app uses in-memory cache - works for 1 instance only.
# Set to connection string from your managed Redis (Render/Upstash/ElastiCache).
REDIS_URL=redis://default:pass@host:6379

# Auth (REQUIRED)
JWT_ACCESS_SECRET=change_me_to_a_long_random_string

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email
# Resend API key (contact + survey notifications)
RESEND_API_KEY=
TO_EMAIL=retlifyy@gmail.com

# SMTP fallback (optional)
SMTP_PASS=

# AI providers
OPENROUTER_API_KEY=
GEMINI_API_KEY=
# Pollinations uses no key

# Concurrency limits (tune to your API tier)
AI_OPENROUTER_CONCURRENCY=20
AI_POLLINATIONS_CONCURRENCY=15
AI_GEMINI_CONCURRENCY=10

# Cluster / scaling
# Number of worker processes per instance. Defaults to CPU count.
WORKERS=2

# CORS - pin to your frontend domain in production
CORS_ORIGIN=https://retlify.com
