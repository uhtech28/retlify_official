# ── Dependencies ─────────────────────────────────────────
node_modules/
.pnp
.pnp.js
 
# ── Environment Variables ─────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
 
# ── Build Output ──────────────────────────────────────────
dist/
build/
.vite/
 
# ── Logs ─────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
 
# ── File Uploads ──────────────────────────────────────────
uploads/
tmp/
temp/
 
# ── Media / Large Assets ──────────────────────────────────
*.mov
*.avi
*.mkv
 
# ── OS Files ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
 
# ── Editor / IDE ──────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
 
# ── Testing & Coverage ────────────────────────────────────
coverage/
.nyc_output/
 
# ── Misc ──────────────────────────────────────────────────
*.tgz
*.zip
.cache/
 @"
# Dependencies
node_modules/
backend/node_modules/

# Environment secrets
.env
backend/.env
*.env.local

# Build output
dist/
build/
backend/dist/

# Logs
*.log
npm-debug.log*
logs/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp

# Zips
*.zip

# Uploads / user data
uploads/
backend/uploads/
"@ | Out-File -FilePath .gitignore -Encoding utf8